networks:
  griddog-network:
    driver: bridge
    name: griddog_network

services:

  java-service:
    build:
      context: {{ repo_dir }}/java-service
      dockerfile: Dockerfile
    container_name: griddog-java-service
    restart: unless-stopped
    networks:
      - griddog-network
    environment:
      PORT: "8081"
      DATABASE_URL: "jdbc:postgresql://{{ databases_private_ip }}:5432/griddog"
      DB_USER: griddog
      DB_PASSWORD: "{{ db_password }}"
      DD_SERVICE: "java-backend-vm"
      DD_VERSION: "2.0.1"
      DD_ENV: "{{ dd_env }}"
      DD_AGENT_HOST: datadog-agent
      DD_LOGS_INJECTION: "true"
      DD_RUNTIME_METRICS_ENABLED: "true"
      DD_PROFILING_ENABLED: "true"
    labels:
      my.custom.label.team: 'java-backend-team'
      com.datadoghq.ad.logs: '[{"source": "java"}]'
      com.datadoghq.tags.env: "{{ dd_env }}"
      com.datadoghq.tags.service: "java-backend-vm"
      com.datadoghq.tags.version: "2.0.1"
    logging:
      driver: json-file
      options:
        max-size: "50m"
        max-file: "3"
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://localhost:8081/actuator/health || exit 1"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 40s

  express-service:
    build:
      context: {{ repo_dir }}/express-service
      dockerfile: Dockerfile
    container_name: griddog-express-service
    restart: unless-stopped
    networks:
      - griddog-network
    environment:
      PORT: "3001"
      MONGODB_URI: "mongodb://{{ databases_private_ip }}:27017/griddog"
      DD_SERVICE: "express-service-vm"
      DD_VERSION: "3.0.1"
      DD_ENV: "{{ dd_env }}"
      DD_AGENT_HOST: datadog-agent
      DD_LOGS_INJECTION: "true"
      DD_RUNTIME_METRICS_ENABLED: "true"
      DD_PROFILING_ENABLED: "true"
    labels:
      my.custom.label.team: 'express-team'
      com.datadoghq.ad.logs: '[{"source": "nodejs"}]'
      com.datadoghq.tags.env: "{{ dd_env }}"
      com.datadoghq.tags.service: "express-service-vm"
      com.datadoghq.tags.version: "3.0.1"
    logging:
      driver: json-file
      options:
        max-size: "50m"
        max-file: "3"
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://localhost:3001/health || exit 1"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 15s

  backend:
    build:
      context: {{ repo_dir }}/backend
      dockerfile: Dockerfile
    container_name: griddog-backend
    restart: unless-stopped
    networks:
      - griddog-network
    ports:
      - "8080:8080"
    environment:
      PORT: "8080"
      JAVA_SERVICE_URL: "http://java-service:8081"
      EXPRESS_SERVICE_URL: "http://express-service:3001"
      TRAFFIC_SERVICE_URL: "http://{{ frontend_private_ip }}:3002"
      DATABASE_URL: "postgres://griddog:{{ db_password }}@{{ databases_private_ip }}:5432/griddog?sslmode=disable"
      DD_SERVICE: "go-backend-vm"
      DD_VERSION: "1.0.1"
      DD_ENV: "{{ dd_env }}"
      DOTNET_SCHEDULER_URL: "http://dotnet-scheduler:5000"
      DD_AGENT_HOST: datadog-agent
      DD_LOGS_INJECTION: "true"
      DD_RUNTIME_METRICS_ENABLED: "true"
      DD_PROFILING_ENABLED: "true"
    labels:
      my.custom.label.team: 'golang-backend-team'
      com.datadoghq.ad.logs: '[{"source": "go"}]'
      com.datadoghq.tags.env: "{{ dd_env }}"
      com.datadoghq.tags.service: "go-backend-vm"
      com.datadoghq.tags.version: "1.0.1"
    logging:
      driver: json-file
      options:
        max-size: "50m"
        max-file: "3"
    depends_on:
      java-service:
        condition: service_healthy
      express-service:
        condition: service_healthy
      dotnet-scheduler:
        condition: service_started
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://localhost:8080/health || exit 1"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 15s

  dotnet-scheduler:
    build:
      context: {{ repo_dir }}/dotnet-scheduler
      dockerfile: Dockerfile
    container_name: griddog-dotnet-scheduler
    restart: unless-stopped
    networks:
      - griddog-network
    environment:
      PORT: "5000"
      DATABASE_URL: "Host={{ databases_private_ip }};Port=5432;Database=griddog;Username=griddog;Password={{ db_password }}"
      DD_SERVICE: "dotnet-scheduler-vm"
      DD_VERSION: "1.0.0"
      DD_ENV: "{{ dd_env }}"
      DD_AGENT_HOST: datadog-agent
      DD_LOGS_INJECTION: "true"
      DD_RUNTIME_METRICS_ENABLED: "true"
    labels:
      my.custom.label.team: 'dotnet-team'
      com.datadoghq.ad.logs: '[{"source": "dotnet"}]'
      com.datadoghq.tags.env: "{{ dd_env }}"
      com.datadoghq.tags.service: "dotnet-scheduler-vm"
      com.datadoghq.tags.version: "1.0.0"
    logging:
      driver: json-file
      options:
        max-size: "50m"
        max-file: "3"
