services:

  nginx:
    image: nginx:alpine
    container_name: griddog-nginx
    restart: unless-stopped
    ports:
      - "80:80"
    volumes:
      - /etc/griddog/nginx.conf:/etc/nginx/nginx.conf:ro
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://localhost/nginx-health || exit 1"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 5s
