# Reference for the Secret that scripts/apply-secrets.sh creates.
# DO NOT apply this file directly — values are placeholders.
# Real values come from secrets.env (gitignored), applied via:
#   ./scripts/apply-secrets.sh
apiVersion: v1
kind: Secret
metadata:
  name: griddog-secrets
  namespace: griddog
type: Opaque
stringData:
  db_password: "REPLACE_ME"
  # dd_api_key will be added in the follow-up Datadog plan
